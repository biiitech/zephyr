config SOC_FAMILY_CH32V
	bool

config SOC_FAMILY_CH5XX
	bool

config SOC_FAMILY
	default "ch32v" if SOC_FAMILY_CH32V
	default "ch5xx" if SOC_FAMILY_CH5XX

rsource "ch32v/*/Kconfig.soc"
rsource "ch5xx/*/Kconfig.soc"
