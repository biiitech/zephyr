/dts-v1/;

#include <wch/ch5xx/ch572d.dtsi>
#include "ch572dk-pinctrl.dtsi"

/ {
	model = "ch572dk";
	compatible = "biii,ch572d";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
	};

	leds {
		compatible = "gpio-leds";
		status = "okay";

		red_led: led0 {
			gpios = <&gpioa 10 GPIO_ACTIVE_HIGH>;
		};
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpioa 8 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "RESET";
		};

		button1: button_1 {
			gpios = <&gpioa 1 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>;
			label = "BOOT";
		};
	};

	aliases {
		led0 = &red_led;
		sw0 = &button0;
		sw1 = &button1;
	};
};

&clk_hse {
	hse-load-capacitance = <12>;
	hse-rated-current = <100>;
};

&rcc {
	clocks = <&pll>; /* PLL 600MHz as system clock source */
	divider = <6>; /* Fsys = 600MHz / 6 = 100MHz */
};

&cpu0 {
	clock-frequency = <DT_FREQ_M(100)>;
};

&i2c1 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
};

&uart0 {
	status = "okay";
	current-speed = <9600>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&spi0 {
	status = "okay";
	pinctrl-0 = <&spi0_default>;
	pinctrl-names = "default";

	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;

	lis2dw12: lis2dw12@0 {
		status = "okay";
		compatible = "st,lis2dw12";
		spi-max-frequency = <8000000>;
		reg = <0>;
	};
};
