/dts-v1/;

#include <wch/ch5xx/ch572d.dtsi>
#include "ch572dk-pinctrl.dtsi"

/ {
	model = "ch572dk";
	compatible = "biii,ch572d";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &usart1;
		zephyr,shell-uart = &usart1;
	};

	leds {
		compatible = "gpio-leds";
		status = "okay";

		red_led: led0 {
			gpios = <&gpioa 10 GPIO_ACTIVE_HIGH>;
		};
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpioa 8 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "RESET";
		};

		button1: button_1 {
			gpios = <&gpioa 1 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>;
			label = "BOOT";
		};
	};

	aliases {
		led0 = &red_led;
		sw0 = &button0;
		sw1 = &button1;
	};
};

&clk_hse {
	hse-load-capacitance = <12>;
	hse-rated-current = <100>;
};

&rcc {
	clocks = <&pll>; // Use 600MHz PLL as system clock source
	divider = <6>; // Set system clock to 100MHz
};

&cpu0 {
	clock-frequency = <DT_FREQ_M(100)>;
};

&i2c1 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
};

&usart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&usart1_default>;
	pinctrl-names = "default";
};

&spi0 {
	status = "okay";
	pinctrl-0 = <&spi0_default>;
	pinctrl-names = "default";
};
