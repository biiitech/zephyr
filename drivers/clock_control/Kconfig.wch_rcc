config CLOCK_CONTROL_WCH_RCC
	bool "WCH CH32V00x Reset and Clock Control (RCC) driver"
	default y
	depends on DT_HAS_WCH_RCC_ENABLED

config CLOCK_CONTROL_WCH_CH5XX_RCC
	bool "WCH CH5XX Reset and Clock Control (RCC) driver"
	default y
	depends on DT_HAS_WCH_CH5XX_RCC_ENABLED
