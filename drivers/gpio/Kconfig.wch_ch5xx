config GPIO_WCH_CH5XX_GPIO
	bool "WCH CH5XX GPIO driver"
	depends on DT_HAS_WCH_CH5XX_GPIO_ENABLED
	default y

config GPIO_WCH_CH5XX_GPIO_INTERRUPTS
	bool "Interrupt support"
	depends on GPIO_WCH_CH5XX_GPIO
	default y
	help
	  Support triggering an interrupt on pin change.
